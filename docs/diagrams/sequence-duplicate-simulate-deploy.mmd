%%{init: {'theme':'neutral'}}%%
sequenceDiagram
    autonumber
    participant U as Utilisateur métier
    participant FE as analytics-frontend
    participant API as analytics-api
    participant K as Ory Keto
    participant YB as YugabyteDB
    participant E as analytics-engine
    participant SIM as analytics-simulator
    participant DF as DragonflyDB
    participant RP as Redpanda
    participant V as Vault

    rect rgb(230,240,255)
        Note over U,FE: 1. Duplication d'un workflow DEPLOYED
        U->>FE: clic "Dupliquer"
        FE->>API: POST /v1/workflows/{id}/duplicate
        API->>K: check analytics:create on subproject
        K-->>API: ALLOW
        API->>YB: INSERT workflows (parent_workflow_id=...)
        API->>YB: INSERT workflow_versions (semver=1.0.0-draft.1, status=DRAFT)
        API->>RP: WORKFLOW_DUPLICATED event
        API-->>FE: 201 WorkflowDetail (new_id, version_id)
        FE-->>U: redirige sur l'éditeur DAG
    end

    rect rgb(245,250,230)
        Note over FE,API: 2. Schema-drift check
        FE->>API: GET /v1/workflows/{id}/schema-drift
        API->>YB: SELECT schema_snapshot FROM workflow_versions
        API->>E: gRPC IntrospectSource(source_ref)
        E->>V: get connector token
        V-->>E: lease 15min
        E-->>API: ActualSchema
        API->>API: diff schemas
        API-->>FE: { new_fields, removed_fields, renamed, type_changes }
        FE-->>U: panneau Drift (résolution interactive)
    end

    rect rgb(255,245,230)
        Note over U,SIM: 3. Simulation sur 1 000 lignes
        U->>FE: bouton "Simuler" (sample=1000, strategy=RANDOM)
        FE->>API: POST /v1/workflows/{id}/versions/{ver}/simulate
        API->>K: check analytics:simulate
        K-->>API: ALLOW
        API->>YB: INSERT simulations (status=QUEUED)
        API->>SIM: dispatch (sim_id, version_id, sample_spec)
        API-->>FE: 202 { simulation_id, websocket_topic }

        FE->>API: SUBSCRIBE /topic/simulation.{sim_id}.progress

        SIM->>E: Compile(definition) → plan_id
        SIM->>YB: SELECT * FROM source LIMIT 1000 (réservoir sampling)
        SIM->>DF: SET simulation:{sim_id}:sample (TTL 24h)
        SIM->>SIM: podman run --read-only --cap-drop=ALL ...
        Note over SIM: sandbox éphémère<br/>seccomp + AppArmor + slirp4netns ACL
        SIM->>RP: SIMULATION_STARTED
        SIM-->>API: progress 25% via STOMP relay
        API-->>FE: STOMP /topic/.../progress { pct: 25 }
        FE-->>U: barre de progression

        SIM->>SIM: Execute plan sur sample
        SIM->>YB: UPDATE simulations SET status=SUCCEEDED, diff_vs_previous=...
        SIM->>RP: SIMULATION_COMPLETED
        SIM-->>API: relay final result
        API-->>FE: STOMP /topic/.../result { diff_url }
        FE->>API: GET /v1/simulations/{sim_id}/diff
        API->>YB: SELECT diff_vs_previous
        API-->>FE: DiffReport
        FE-->>U: comparateur côte-à-côte v1.2.0 / v1.3.0-draft
    end

    rect rgb(250,230,250)
        Note over U,API: 4. Approbation (4-eyes si is_critical)
        U->>FE: clic "Approuver"
        FE->>API: POST /v1/workflows/{id}/versions/{ver}/approve
        API->>K: check analytics:approve (et ≠ editor)
        K-->>API: ALLOW
        API->>YB: INSERT approvals
        API->>YB: COUNT approvals WHERE version_id=...
        Note over API: si is_critical=true et count<2 → ready_to_deploy=false
        API-->>FE: { approvals_count: 1, approvals_required: 2, ready_to_deploy: false }
        FE-->>U: "En attente d'un 2e approbateur"
    end

    rect rgb(230,250,250)
        Note over U,API: 5. Déploiement SHADOW
        U->>FE: clic "Déployer" (strategy=SHADOW, 24h)
        FE->>API: POST /v1/workflows/{id}/versions/{ver}/deploy
        API->>K: check analytics:deploy AND approver count >= required
        K-->>API: ALLOW
        API->>YB: UPDATE workflow_versions SET status=DEPLOYED, deployed_at=now()
        API->>YB: UPDATE workflow_versions previous SET status=DEPRECATED
        API->>YB: INSERT deployments (strategy=SHADOW, shadow_ends_at=now+24h)
        API->>RP: VERSION_DEPLOYED
        API->>DF: invalidate {workflow:id}:*
        API-->>FE: 200 Deployment
        FE-->>U: badge "DEPLOYED 1.3.0 (shadow 24h)"
    end
