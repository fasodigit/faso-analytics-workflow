# FASO-ANALYTICS-WORKFLOW — variables d'environnement (exemple — ne pas committer .env réel)
COMPOSE_PROJECT_NAME=faso_analytics

# Yugabyte (dev local)
YB_HOST=yugabyte
YB_PORT=5433
YB_USER=yugabyte
YB_PASSWORD=yugabyte
YB_DB=yugabyte

# Dragonfly
DRAGONFLY_URL=redis://dragonfly:6379

# Redpanda
KAFKA_BOOTSTRAP=redpanda:9092
TOPIC_WORKFLOW_EVENTS=faso.analytics.workflow.events

# Vault (dev mode root token — JAMAIS en prod)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Keto
KETO_READ_URL=http://keto:4466
KETO_WRITE_URL=http://keto:4467

# Engine gRPC
ENGINE_GRPC_ADDR=analytics-engine:50051
SIMULATOR_GRPC_ADDR=analytics-simulator:50052

# JWT (à pulled depuis Vault en prod)
JWT_ISSUER=https://armageddon.faso-digitalisation.bf
JWT_AUDIENCE=analytics-api

# Sandbox
SANDBOX_IMAGE=faso/analytics-sandbox:1.0
SANDBOX_TIMEOUT_SEC_SMALL=60
SANDBOX_TIMEOUT_SEC_MEDIUM=300
SANDBOX_TIMEOUT_SEC_LARGE=600
SANDBOX_MEMORY_MAX=2g
SANDBOX_CPU_MAX=2.0
